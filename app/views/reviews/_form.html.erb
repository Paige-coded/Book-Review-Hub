<%= form_with model: [@book, @review] do |form| %>
  <% if @review.errors.any? %>
    <div class="px-6 py-4 rounded mb-6" style="background: #3d1010; border: 1px solid #c0392b; color: #e88;">
      <% @review.errors.full_messages.each do |msg| %>
        <p class="text-sm">✦ <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="space-y-5">
    <div>
      <%= form.label :body, "Your Review", class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
      <%= form.text_area :body, rows: 5,
          class: "w-full px-4 py-3 rounded text-sm focus:outline-none focus:ring-2 focus:ring-yellow-600",
          style: "background: #f5f0e8; color: #1a0f0a; border: 2px solid #b8860b; font-family: 'Raleway', sans-serif;" %>
    </div>

    <div>
      <%= form.label :rating, "Rating (1–5)", class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
      <%= form.number_field :rating, min: 1, max: 5,
          class: "w-32 px-4 py-3 rounded text-sm focus:outline-none focus:ring-2 focus:ring-yellow-600",
          style: "background: #f5f0e8; color: #1a0f0a; border: 2px solid #b8860b;" %>
    </div>

    <div class="pt-2">
      <%= form.submit "Submit Review",
          class: "shelf-btn w-full py-3 rounded text-sm tracking-widest uppercase font-medium cursor-pointer",
          style: "background: linear-gradient(135deg, #8b6914, #c9a84c); color: #0d0604; border: none;" %>
    </div>
  </div>
<% end %>