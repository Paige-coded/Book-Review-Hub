<%= form_with model: @book do |form| %>
  <% if @book.errors.any? %>
    <div class="px-6 py-4 rounded mb-6" style="background: #3d1010; border: 1px solid #c0392b; color: #e88;">
      <% @book.errors.full_messages.each do |msg| %>
        <p class="text-sm">✦ <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="space-y-6">
    <div>
      <%= form.label :title, class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
      <%= form.text_field :title,
          class: "w-full px-4 py-3 rounded text-sm focus:outline-none focus:ring-2",
          style: "background: #f5f0e8; color: #1a0f0a; border: 1px solid #b8860b; font-family: 'Raleway', sans-serif;" %>
    </div>

    <div>
      <%= form.label :author, class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
      <%= form.text_field :author,
          class: "w-full px-4 py-3 rounded text-sm focus:outline-none",
          style: "background: #f5f0e8; color: #1a0f0a; border: 1px solid #b8860b; font-family: 'Raleway', sans-serif;" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
      <%= form.text_area :description, rows: 4,
          class: "w-full px-4 py-3 rounded text-sm focus:outline-none",
          style: "background: #f5f0e8; color: #1a0f0a; border: 1px solid #b8860b; font-family: 'Raleway', sans-serif;" %>
    </div>

    <div>
      <%= form.label :cover_url, "Cover Image URL", class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
      <%= form.text_field :cover_url,
          class: "w-full px-4 py-3 rounded text-sm focus:outline-none",
          style: "background: #f5f0e8; color: #1a0f0a; border: 1px solid #b8860b; font-family: 'Raleway', sans-serif;" %>
    </div>

    <div class="pt-2">
      <%= form.submit class: "shelf-btn w-full py-3 rounded text-sm tracking-widest uppercase font-medium cursor-pointer",
          style: "background: linear-gradient(135deg, #8b6914, #c9a84c); color: #0d0604; border: none;" %>
    </div>
  </div>
<% end %>