<div class="max-w-md mx-auto">
  <div class="mb-8 text-center">
    <h1 class="fancy text-4xl font-bold mb-2" style="color: #ffd700;">Join The Shelf</h1>
    <p class="text-xs tracking-widest uppercase" style="color: #8a6f3d;">Create your account</p>
    <div class="w-24 h-px mx-auto mt-4" style="background: linear-gradient(90deg, transparent, #b8860b, transparent);"></div>
  </div>

  <div class="rounded-lg p-8" style="background: linear-gradient(135deg, #1e140a, #2c1810); border: 1px solid #3d2810;">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <% if resource.errors.any? %>
        <div class="px-6 py-4 rounded mb-6" style="background: #3d1010; border: 1px solid #c0392b; color: #e88;">
          <% resource.errors.full_messages.each do |msg| %>
            <p class="text-sm">✦ <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-3 rounded text-sm focus:outline-none focus:ring-2 focus:ring-yellow-600",
              style: "background: #f5f0e8; color: #1a0f0a; border: 2px solid #b8860b;" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full px-4 py-3 rounded text-sm focus:outline-none focus:ring-2 focus:ring-yellow-600",
              style: "background: #f5f0e8; color: #1a0f0a; border: 2px solid #b8860b;" %>
          <p class="text-xs mt-1" style="color: #5c3d1e;">6 characters minimum</p>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-xs tracking-widest uppercase mb-2", style: "color: #c9a84c;" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full px-4 py-3 rounded text-sm focus:outline-none focus:ring-2 focus:ring-yellow-600",
              style: "background: #f5f0e8; color: #1a0f0a; border: 2px solid #b8860b;" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Create Account", class: "shelf-btn w-full py-3 rounded text-sm tracking-widest uppercase font-medium cursor-pointer",
              style: "background: linear-gradient(135deg, #8b6914, #c9a84c); color: #0d0604; border: none;" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <p class="text-xs" style="color: #5c3d1e;">Already have an account?
        <%= link_to "Sign In", new_user_session_path, style: "color: #c9a84c;" %>
      </p>
    </div>
  </div>
</div>